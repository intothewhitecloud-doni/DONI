{
  "name": "enterprise-ai-decision-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "npm run typecheck && npm run test:policy && npm run build",
    "test:policy": "node -e \"require('node:fs').rmSync('.omx/test-build',{recursive:true,force:true})\" && tsc -p tsconfig.policy-test.json && node --test \".omx/test-build/src/**/*.test.js\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "framer-motion": "^12.38.0",
    "next": "16.2.5",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "postcss": "8.5.14",
    "tailwindcss": "3.4.17",
    "typescript": "latest"
  }
}
